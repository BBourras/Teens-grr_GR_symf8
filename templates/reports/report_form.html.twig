{# templates/reports/report_form.html.twig #}

{% extends 'base.html.twig' %}

{% block title %}Signaler un {{ type == 'post' ? 'post' : 'commentaire' }} — Teens-GRR{% endblock %}

{% block body %}

<div class="row justify-content-center mt-5">
    <div class="col-lg-8 col-xl-6">

        <div class="card shadow-sm">
            <div class="card-header bg-danger text-white py-3">
                <h4 class="mb-0">
                    <i class="bi bi-flag-fill me-2"></i>
                    Signaler un {{ type == 'post' ? 'post' : 'commentaire' }}
                </h4>
            </div>

            <div class="card-body">

                <div class="alert alert-warning">
                    <strong>Attention :</strong> Utilisez cette fonctionnalité uniquement pour du contenu inapproprié, 
                    du harcèlement, des insultes ou des propos haineux. Les abus seront sanctionnés.
                </div>

                {{ form_start(form) }}

                    {# Raison du signalement #}
                    <div class="mb-4">
                        <label class="form-label fw-bold">
                            Raison du signalement <span class="text-danger">*</span>
                        </label>
                        {{ form_widget(form.reason, {
                            'attr': {'class': 'form-select'}
                        }) }}
                        {{ form_errors(form.reason) }}
                    </div>

                    {# Précisions supplémentaires #}
                    <div class="mb-4">
                        <label class="form-label fw-bold">Précisions supplémentaires (facultatif)</label>
                        {{ form_widget(form.reason_detail, {
                            'attr': {
                                'class': 'form-control',
                                'rows': 6,
                                'placeholder': 'Décrivez brièvement pourquoi vous signalez ce contenu...'
                            }
                        }) }}
                        {{ form_errors(form.reason_detail) }}
                    </div>

                    {# Boutons #}
                    <div class="d-flex gap-3 mt-4">
                        <a href="{{ path('post_show', {id: content.id}) }}" 
                           class="btn btn-secondary flex-fill">
                            Annuler
                        </a>
                        <button type="submit" class="btn btn-danger flex-fill">
                            <i class="bi bi-flag"></i> Envoyer le signalement
                        </button>
                    </div>

                {{ form_end(form) }}

            </div>
        </div>

        <p class="text-center text-muted small mt-4">
            Votre signalement sera examiné par un modérateur dans les plus brefs délais.<br>
            Merci de contribuer à la qualité de la communauté.
        </p>

    </div>
</div>

{% endblock %}