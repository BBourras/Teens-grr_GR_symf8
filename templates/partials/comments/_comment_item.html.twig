{# templates/partials/comments/_comment_item.html.twig #}

<div class="comment-item border-start border-3 border-primary ps-3 mb-4 {% if not comment.isVisible() %}opacity-75 bg-light{% endif %}">

    <div class="d-flex justify-content-between align-items-start">
        <div>
            <strong class="me-2">{{ comment.author.username }}</strong>
            <small class="text-muted">
                {{ comment.createdAt|date('d/m/Y - H:i') }}
            </small>
        </div>

        {# Statut si masqué #}
        {% if not comment.isVisible() %}
            <span class="badge bg-warning text-dark small">
                {% if comment.isAutoModerated() %}Masqué auto{% else %}Masqué modérateur{% endif %}
            </span>
        {% endif %}
    </div>

    <div class="mt-2 fs-6 lh-base">
        {{ comment.content|nl2br }}
    </div>

    {# Actions sur le commentaire (uniquement pour l'auteur ou modérateur) #}
    {% if is_granted('ROLE_USER') %}
        <div class="mt-3 small">
            {% if app.user and app.user.id == comment.author.id %}
                <a href="#" class="text-danger me-3 delete-comment-link" 
                   data-comment-id="{{ comment.id }}">
                    <i class="bi bi-trash"></i> Supprimer
                </a>
            {% endif %}

            {% if is_granted('ROLE_MODERATOR') %}
                <a href="#" class="text-warning me-3">
                    <i class="bi bi-shield-check"></i> Modérer
                </a>
            {% endif %}
        </div>
    {% endif %}

</div>