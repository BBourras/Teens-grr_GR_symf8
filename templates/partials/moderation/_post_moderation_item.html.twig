{#
    templates/partials/moderation/_post_moderation_item.html.twig
    -------------------------------------------------------
    Affichage d'un post en attente de décision manuelle
    dans le dashboard de modération.

    Affiche les 3 actions disponibles :
    - Restaurer  → moderation_post_restore
    - Masquer    → moderation_post_hide
    - Supprimer  → moderation_post_delete

    Chaque formulaire inclut :
    - Token CSRF (id unique par post et par action)
    - Champ reason optionnel (raison de la décision)

    Variables attendues :
        - post : entité Post

    Usage :
        {% for post in posts %}
            {{ include('partials/moderation/_post_moderation_item.html.twig', { post: post }) }}
        {% endfor %}
#}
<div class="card mb-3 border-warning shadow-sm">
  <div class="card-body">
    {# Titre du post — lien vers sa page publique #}
    <h5 class="card-title">
      <a href="{{
        path(
          'post_show',
          {
            id: post.id
          }
        )
        }}"
        target="_blank"
        class="text-decoration-none">
        {{ post.title }}
      </a>
    </h5>

    {# Métadonnées #}
    <p class="text-muted small mb-2">
      Par <strong>{{ post.author.username }}</strong>
      • {{ post.createdAt|date('d/m/Y - H:i') }}
      • <span class="badge bg-warning text-dark">
        ⚠️ {{ post.reportCount }} signalement{{ post.reportCount > 1 ? 's' : '' }}
      </span>
      • Statut : <em>{{ post.status.label() }}</em>
    </p>

    {# Contenu tronqué #}
    <p class="mb-3">
      {{ post.content|striptags|u.truncate(300, '…', false) }}
    </p>

    {# Champ raison commun — sera copié dans chaque formulaire via JS ou dupliqué #}
    <div class="mb-3">
      <label class="form-label small text-muted">
        Raison de la décision (optionnel)
      </label>
      <input type="text"
        id="reason-post-{{ post.id }}"
        class="form-control form-control-sm"
        placeholder="Ex : contenu haineux, hors-sujet…"
        maxlength="255" />
    </div>

    {# Actions #}
    <div class="d-flex gap-2 flex-wrap">
      {# Restaurer (infirme les signalements) #}
      <form action="{{
        path(
          'moderation_post_restore',
          {
            id: post.id
          }
        )
        }}"
        method="post"
        class="moderation-form"
        data-reason-source="reason-post-{{ post.id }}">
        <input type="hidden"
          name="_token"
          value="{{ csrf_token('moderation_post_' ~ post.id) }}" />
        <input type="hidden" name="reason" class="reason-field" />
        <button type="submit" class="btn btn-sm btn-success">
          ✅ Restaurer
        </button>
      </form>

      {# Masquer manuellement (confirme les signalements) #}
      <form action="{{
        path(
          'moderation_post_hide',
          {
            id: post.id
          }
        )
        }}"
        method="post"
        class="moderation-form"
        data-reason-source="reason-post-{{ post.id }}">
        <input type="hidden"
          name="_token"
          value="{{ csrf_token('moderation_post_' ~ post.id) }}" />
        <input type="hidden" name="reason" class="reason-field" />
        <button type="submit" class="btn btn-sm btn-warning">🚫 Masquer</button>
      </form>

      {# Supprimer définitivement #}
      <form action="{{
        path(
          'moderation_post_delete',
          {
            id: post.id
          }
        )
        }}"
        method="post"
        class="moderation-form"
        data-reason-source="reason-post-{{ post.id }}">
        <input type="hidden"
          name="_token"
          value="{{ csrf_token('moderation_post_' ~ post.id) }}" />
        <input type="hidden" name="reason" class="reason-field" />
        <button type="submit"
          class="btn btn-sm btn-danger"
          onclick="return confirm('Supprimer définitivement ce post ?')">
          🗑 Supprimer
        </button>
      </form>
    </div>
  </div>
</div>
