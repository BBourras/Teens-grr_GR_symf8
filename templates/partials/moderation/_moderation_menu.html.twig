{#
    templates/partials/moderation/_moderation_menu.html.twig
    -------------------------------------------------------
    Menu latéral du dashboard de modération.

    Variables attendues :
        - posts    : tableau de Post auto-masqués
        - comments : tableau de Comment auto-masqués

    Usage :
        {{ include('partials/moderation/_moderation_menu.html.twig', {
            posts: posts,
            comments: comments
        }) }}
#}
<div class="list-group sticky-top" style="top: 1rem;">

    <a href="{{ path('moderation_dashboard') }}"
       class="list-group-item list-group-item-action fw-bold">
        🛡 Dashboard
    </a>

    <a href="#posts-section"
       class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
        Posts masqués
        {% if posts|length > 0 %}
            <span class="badge bg-warning text-dark rounded-pill">
                {{ posts|length }}
            </span>
        {% endif %}
    </a>

    <a href="#comments-section"
       class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
        Commentaires masqués
        {% if comments|length > 0 %}
            <span class="badge bg-warning text-dark rounded-pill">
                {{ comments|length }}
            </span>
        {% endif %}
    </a>

    <div class="list-group-item list-group-item-secondary small text-muted mt-2">
        Total en attente :
        <strong>{{ posts|length + comments|length }}</strong>
    </div>

</div>
