{# templates/partials/navbar/_navbar.html.twig #}

<nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm mb-4">
  <div class="container">
    {# Logo / Brand #}
    <a class="navbar-brand fw-bold d-flex align-items-center"
      href="{{ path('app_home') }}">
      Teens-GRR
      <span class="text-muted fs-6 fw-normal ms-2 d-none d-md-inline">
        Le blog interdit aux adolescents ! LOL !
      </span>
    </a>

    {# Bouton toggle mobile #}
    <button class="navbar-toggler"
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#navMain"
      aria-controls="navMain"
      aria-expanded="false"
      aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navMain">
      {# Navigation principale (liens publics) #}
      <ul class="navbar-nav me-auto">
        <li class="nav-item">
          <a class="nav-link nav-icon nav-link--highlight"
            href="{{ path('post_recent') }}">
            <i class="bi bi-rss nav-icon__icon me-1"></i>
            Récemment
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link nav-icon nav-link--highlight"
            href="{{ path('post_trending') }}">
            <i class="bi bi-trophy nav-icon__icon me-1"></i>
            Top du moment
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link nav-icon nav-link--highlight"
            href="{{ path('post_legend') }}">
            <i class="bi bi-bank nav-icon__icon me-1"></i>
            Légendes
          </a>
        </li>

        {# Modération - visible uniquement aux modérateurs #}
        {% if is_granted('ROLE_MODERATOR') %}
          <li class="nav-item">
            <a class="nav-link text-warning nav-icon"
              href="{{ path('moderation_dashboard') }}">
              <i class="bi bi-shield-check nav-icon__icon me-1"></i>
              Modération
            </a>
          </li>
        {% endif %}
      </ul>

      {# Menu utilisateur / authentification #}
      <ul class="navbar-nav">
        {% if app.user %}
          {# Utilisateur connecté #}
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle d-flex align-items-center nav-icon nav-link--user"
              href="#"
              role="button"
              data-bs-toggle="dropdown"
              aria-expanded="false">
              <i class="bi bi-person-circle nav-icon__icon me-2"></i>
              {{ app.user.username }}
            </a>
            <ul class="dropdown-menu dropdown-menu-end">
              <li>
                <a class="dropdown-item" href="{{ path('user_dashboard') }}">
                  <i class="bi bi-house-door me-2"></i> Tableau de bord
                </a>
              </li>
              <li>
                <a class="dropdown-item" href="{{ path('post_create') }}">
                  <i class="bi bi-plus-circle me-2"></i> Nouveau post
                </a>
              </li>
              <li><hr class="dropdown-divider" /></li>
              <li>
                <a class="dropdown-item text-danger"
                  href="{{ path('app_logout') }}">
                  <i class="bi bi-box-arrow-right me-2"></i> Déconnexion
                </a>
              </li>
            </ul>
          </li>
        {% else %}
          {# Utilisateur non connecté #}
          <li class="nav-item">
            <a class="nav-link nav-icon login-link"
              href="{{ path('app_login') }}">
              <i class="bi bi-box-arrow-in-right nav-icon__icon me-1"></i>
              Connexion
            </a>
          </li>

          <li class="nav-item ms-2">
            <a class="nav-link nav-icon btn btn-outline-light px-3"
              href="{{ path('app_register') }}">
              <i class="bi bi-person-plus nav-icon__icon me-1"></i>
              Inscription
            </a>
          </li>
        {% endif %}
      </ul>
    </div>
  </div>
</nav>
