{# templates/partials/posts/_post_card_with_votes.html.twig #}

<div class="card h-100">
    <div class="card-body">
        <h5 class="card-title">{{ post.title }}</h5>
        
        <p class="card-text text-muted small mb-2">
            par {{ post.author.username }} • {{ post.createdAt|date('d/m/Y - H:i') }}
        </p>

        <p class="card-text">
            {{ post.content|slice(0, 180) }}{% if post.content|length > 180 %}…{% endif %}
        </p>

        <div class="mt-3">
            <span class="badge 
                {% if post.isVisible() %}bg-success
                {% elseif post.isAutoModerated() %}bg-warning
                {% elseif post.isManuallyModerated() %}bg-danger
                {% else %}bg-secondary{% endif %}">
                {{ post.getStatusEnum().label() }}
            </span>
        </div>
    </div>

    {# Votes intégrés directement dans la carte #}
    <div class="card-footer bg-transparent pt-0">
        {{ include('partials/posts/_post_votes.html.twig', {
            post:       post,
            postScores: scores|default({}),
            userVote:   userVote|default(null)
        }) }}
    </div>
</div>