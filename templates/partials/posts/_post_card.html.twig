{# templates/partials/posts/_post_card.html.twig #}

<div class="card h-100 shadow-sm post-card {% if not post.isVisible() %}border-warning bg-light{% endif %}">

    <div class="card-body d-flex flex-column">

        {# Titre #}
        <h5 class="card-title">
            <a href="{{ path('post_show', {id: post.id}) }}" class="text-decoration-none">
                {{ post.title }}
            </a>
        </h5>

        {# Extrait #}
        <p class="card-text text-muted flex-grow-1">
            {{ post.getExcerpt(160) }}
        </p>

        {# Auteur + date #}
        <div class="d-flex justify-content-between align-items-center small text-muted mt-auto">
            <span>
                <i class="bi bi-person-circle"></i> {{ post.author.username }}
            </span>
            <span class="text-end">
                {{ post.createdAt|date('d/m/Y - H:i') }}
            </span>
        </div>

    </div>

    {# Footer : Votes + Actions #}
    <div class="card-footer bg-transparent border-0 pt-0">

        {# Votes #}
        {% include 'partials/posts/_post_votes.html.twig' with {
            post: post,
            postScores: postScores|default({}),
            userVote: userVote|default(null)
        } %}

        {# Boutons d'action #}
        <div class="d-flex gap-2 mt-3">
            <a href="{{ path('post_show', {id: post.id}) }}#comments" 
               class="btn btn-sm btn-outline-primary flex-fill">
                <i class="bi bi-chat-dots"></i> Commenter
            </a>

            {% if is_granted('ROLE_USER') %}
                <a href="{{ path('report_post', {id: post.id}) }}" 
                   class="btn btn-sm btn-outline-danger flex-fill">
                    <i class="bi bi-flag"></i> Signaler
                </a>
            {% else %}
                <a href="{{ path('app_login') }}" 
                   class="btn btn-sm btn-outline-danger flex-fill">
                    <i class="bi bi-flag"></i> Signaler
                </a>
            {% endif %}
        </div>

        {# Statut de modération #}
        {% if not post.isVisible() %}
            <div class="mt-3">
                {% if post.isAutoModerated() %}
                    <span class="badge bg-warning text-dark">Masqué automatiquement</span>
                {% elseif post.isManuallyModerated() %}
                    <span class="badge bg-danger">Masqué par modérateur</span>
                {% elseif post.isDeleted() %}
                    <span class="badge bg-secondary">Supprimé</span>
                {% endif %}
            </div>
        {% endif %}

    </div>
</div>