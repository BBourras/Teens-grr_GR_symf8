{# templates/partials/posts/_post_form.html.twig #}

{{ form_start(form, {attr: {class: 'post-form'}}) }}

    <div class="mb-4">
        {{ form_label(form.title, 'Titre du post') }}
        {{ form_widget(form.title, {
            attr: {
                class: 'form-control form-control-lg',
                placeholder: 'Un titre bien ironique...'
            }
        }) }}
        {{ form_errors(form.title) }}
    </div>

    <div class="mb-4">
        {{ form_label(form.content, 'Contenu') }}
        {{ form_widget(form.content, {
            attr: {
                class: 'form-control',
                rows: 12,
                placeholder: 'Racontez votre anecdote sur les ados...'
            }
        }) }}
        {{ form_errors(form.content) }}
    </div>

    <div class="d-grid gap-2">
        <button type="submit" class="btn btn-primary btn-lg">
            {% if form.vars.value.id %}
                Modifier le post
            {% else %}
                Publier le post
            {% endif %}
        </button>
    </div>

{{ form_end(form) }}