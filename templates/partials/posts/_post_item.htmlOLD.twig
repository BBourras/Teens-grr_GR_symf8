{#
    templates/partials/posts/_post_item.html.twig
    -------------------------------------------------------
    Affichage minimaliste d'un post dans une liste compacte.
    Utilisé dans la sidebar home ou les listes légères.

    Variables attendues :
        - post : entité Post

    Usage :
        {% for post in posts %}
            {{ include('partials/posts/_post_item.html.twig', { post: post }) }}
        {% endfor %}
#}
<div class="post-item mb-2">
    <h6 class="mb-1">
        {# Paramètre 'id' conforme à la route post_show #}
        <a href="{{ path('post_show', { id: post.id }) }}" class="text-decoration-none">
            {{ post.title }}
        </a>
    </h6>
    <p class="text-muted small mb-0">
        {# |striptags évite les entités HTML cassées au découpage #}
        {{ post.content|striptags|u.truncate(100, '…', false) }}
    </p>
</div>
