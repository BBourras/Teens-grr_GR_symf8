{#
    templates/partials/posts/_post_votes.html.twig
    -------------------------------------------------------
    Bloc de vote / réaction réutilisable pour un post.

    Accessible à TOUS (connectés ET invités).
    - Connecté : vote libre, modifiable
    - Invité   : 1 vote / 24h via cookie UUID (géré par VoteController)

    Variables attendues :
        - post       : entité Post
        - postScores : tableau ['laugh' => N, 'angry' => N, 'disillusioned' => N]
        - userVote   : valeur string du vote actuel de l'utilisateur,
                       ou null si pas de vote actif
                       (ex: 'laugh', 'angry', 'disillusioned')

    Usage :
        {{ include('partials/posts/_post_votes.html.twig', {
            post: post,
            postScores: postScores,
            userVote: userVote|default(null)
        }) }}
#}

{# ── Sécurisation des compteurs ──────────────────────────────────────── #}
{% set laugh         = postScores['laugh']|default(0) %}
{% set angry         = postScores['angry']|default(0) %}
{% set disillusioned = postScores['disillusioned']|default(0) %}
{% set total         = laugh + angry + disillusioned %}

{# ── Pourcentages (protégé contre division par zéro) ─────────────────── #}
{% set laughPercent = total > 0 ? (laugh / total * 100)|round : 0 %}
{% set angryPercent = total > 0 ? (angry / total * 100)|round : 0 %}
{% set disPercent   = total > 0 ? (disillusioned / total * 100)|round : 0 %}

{#
    Le formulaire est affiché pour TOUS (connectés et invités).
    Le VoteController identifie les invités via le cookie guest_vote_key.
    Pas de ROLE_USER requis ici — conformément au cahier des charges.
#}
<form method="post"
      action="{{ path('vote_post', { id: post.id }) }}"
      class="d-flex gap-2 align-items-center flex-wrap">

    {# ── Laugh (😂) ────────────────────────────────────────────────────── #}
    <button name="type" value="laugh"
            class="btn btn-sm {{ userVote == 'laugh' ? 'btn-warning' : 'btn-outline-warning' }}"
            title="Trop drôle">
        😂 {{ laugh }}
        {% if total > 0 %}
            <small>({{ laughPercent }}%)</small>
        {% endif %}
    </button>

    {# ── Disillusioned (😏) ───────────────────────────────────────────── #}
    <button name="type" value="disillusioned"
            class="btn btn-sm {{ userVote == 'disillusioned' ? 'btn-secondary' : 'btn-outline-secondary' }}"
            title="Tellement vrai…">
        😏 {{ disillusioned }}
        {% if total > 0 %}
            <small>({{ disPercent }}%)</small>
        {% endif %}
    </button>

    {# ── Angry (😡) ───────────────────────────────────────────────────── #}
    <button name="type" value="angry"
            class="btn btn-sm {{ userVote == 'angry' ? 'btn-danger' : 'btn-outline-danger' }}"
            title="Énervant">
        😡 {{ angry }}
        {% if total > 0 %}
            <small>({{ angryPercent }}%)</small>
        {% endif %}
    </button>

    {# ── Score pondéré ────────────────────────────────────────────────── #}
    <span class="ms-2 text-muted small">
        Score :
        <strong class="{{ post.reactionScore < 0 ? 'text-danger' : '' }}">
            {{ post.reactionScore }}
        </strong>
    </span>

</form>

{# ── Badges éditoriaux ────────────────────────────────────────────────── #}
{% if total > 0 %}
    <div class="mt-2 d-flex gap-1 flex-wrap">
        {% if laugh > 20 %}
            <span class="badge bg-success">😂 Très drôle</span>
        {% endif %}
        {% if disillusioned > laugh %}
            <span class="badge bg-dark">😏 Désabusé</span>
        {% endif %}
        {% if angryPercent > 40 %}
            <span class="badge bg-danger">😠 Pas content</span>
        {% endif %}
        {% if post.reactionScore < 0 %}
            <span class="badge bg-secondary"> 😨 Les ados contre-attaquent 🕷️ </span>
        {% endif %}
    </div>
{% endif %}
