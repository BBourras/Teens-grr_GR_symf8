{#
    templates/partials/posts/_post_card.html.twig
    -------------------------------------------------------
    Affiche un post sous forme de card Bootstrap.
    Utilisé dans les listes (home, top, légendes).

    Variables attendues :
        - post    : entité Post
        - scores  : tableau ['laugh' => N, 'angry' => N, 'disillusioned' => N]
                    (optionnel — si absent, les scores ne s'affichent pas)

    Usage :
        {% for post in posts %}
            {{ include('partials/posts/_post_card.html.twig', {
                post: post,
                scores: scores[post.id]|default({})
            }) }}
        {% endfor %}
#}
<div class="card mb-3">
    <div class="card-body">

        {# Titre — lien vers le post #}
        <h5 class="card-title">
            <a href="{{ path('post_show', { id: post.id }) }}" class="text-decoration-none">
                {{ post.title }}
            </a>
        </h5>

        {# Métadonnées #}
        <p class="text-muted small mb-2">
            Par <strong>{{ post.author.username }}</strong>
            • {{ post.createdAt|date('d/m/Y à H:i') }}
        </p>

        {# Extrait du contenu.
           |striptags évite les entités HTML cassées,
           |u.truncate coupe proprement sans couper un mot. #}
        <p class="card-text">
            {{ post.content|striptags|u.truncate(200, '…', false) }}
        </p>

        {# Compteurs et actions #}
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">

            {# Compteurs dénormalisés #}
            <span class="text-muted small">
                💬 {{ post.commentCount }}
                &nbsp;
                ⚡ {{ post.reactionScore }}
                {% if scores is defined and scores %}
                    &nbsp;
                    😂 {{ scores['laugh']|default(0) }}
                    😏 {{ scores['disillusioned']|default(0) }}
                    😡 {{ scores['angry']|default(0) }}
                {% endif %}
            </span>

            {# Actions auteur #}
            {% if is_granted('POST_EDIT', post) %}
                <a href="{{ path('post_edit', { id: post.id }) }}"
                   class="btn btn-sm btn-outline-secondary">
                    Modifier
                </a>
            {% endif %}

        </div>
    </div>
</div>
