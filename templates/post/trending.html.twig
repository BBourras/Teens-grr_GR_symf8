{# templates/post/trending.html.twig #}

{% extends 'base.html.twig' %}

{% block title %}
  Top du moment
{% endblock %}

{% block body %}
  <h1 class="mb-2">
    <i class="bi bi-trophy me-2"></i> Top du moment
  </h1>
  <p class="text-muted mb-4">
    Découvrez <strong>les posts les plus plébiscités</strong> en ce moment !
  </p>

  <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    {% for post in posts %}
      <div class="col">
        {% include 'partials/posts/_post_card.html.twig' with {
          post: post,
          postScores: postScores[post.id]|default({}),
          userVote: userVotes[post.id]|default(null)
        } %}
      </div>
    {% else %}
      <div class="col-12">
        <div class="alert alert-info text-center py-5">
          Soyez le premier à témoigner !
        </div>
      </div>
    {% endfor %}
  </div>
{% endblock %}
