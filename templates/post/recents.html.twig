{# templates/post/recents.html.twig #}

{% extends 'base.html.twig' %}

{% block title %}
  Posts récents
{% endblock %}

{% block body %}
  <h1 class="mb-2">
    <i class="bi bi-rss me-2"></i> Les derniers arrivés
  </h1>
  <p class="text-muted mb-4">
    Découvrez <strong>les posts les plus récents</strong> !
  </p>

  {% if is_granted('ROLE_USER') %}
    <a href="{{ path('post_create') }}" class="btn btn-primary mb-4">
      <i class="bi bi-plus-circle me-1"></i> Nouveau post
    </a>
  {% endif %}

  {% include 'partials/flash/_flash_messages.html.twig' %}

  <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 mb-5">
    {% for post in pagination %}
      <div class="col">
        {% include 'partials/posts/_post_card.html.twig' with {
          post: post,
          postScores: postScores[post.id]|default({}),
          userVote: null
        } %}
      </div>
    {% else %}
      <div class="col-12">
        <div class="alert alert-info text-center py-5">
          <i class="bi bi-rss display-4 text-muted mb-3"></i>
          <h5>
            Aucun post pour le moment.
          </h5>

          {% if is_granted('ROLE_USER') %}
            <a href="{{ path('post_create') }}" class="btn btn-primary mt-3">
              Soyez le premier à publier !
            </a>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>

  {# Pagination Knp #}
  <div class="d-flex justify-content-center mt-5">
    {{ knp_pagination_render(pagination) }}
  </div>
{% endblock %}
