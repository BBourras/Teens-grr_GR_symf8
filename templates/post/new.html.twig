{# templates/post/new.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Créer un message{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-8">

        <h2 class="mb-4">📝 Publier un nouveau message</h2>

        {% include 'partials/flash/_flash_messages.html.twig' %}

        {{ form_start(form, { attr: { novalidate: 'novalidate' } }) }}

            <div class="mb-3">
                {{ form_label(form.title) }}
                {{ form_widget(form.title, { attr: { class: 'form-control' } }) }}
                {{ form_errors(form.title) }}
            </div>

            <div class="mb-3">
                {{ form_label(form.content) }}
                {{ form_widget(form.content, { attr: { class: 'form-control' } }) }}
                {{ form_errors(form.content) }}
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    Publier
                </button>
                <a href="{{ path('post_recent') }}" class="btn btn-outline-secondary">
                    Annuler
                </a>
            </div>

        {{ form_end(form) }}

    </div>
</div>
{% endblock %}
