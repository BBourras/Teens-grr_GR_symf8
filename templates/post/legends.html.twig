{# templates/post/legends.html.twig #}

{% extends 'base.html.twig' %}

{% block title %}
  Légendes
{% endblock %}

{% block body %}
  {# <div class="container mt-4"> #}
  <h1 class="mb-2">
    <i class="bi bi-bank me-1"></i> Les légendes
  </h1>
  <p class="text-muted mb-4">
    Relisez <strong>les posts cultes</strong> qui se sont imposés au fil du temps
    !
  </p>

  <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    {% for post in posts %}
      <div class="col">
        {% include 'partials/posts/_post_card.html.twig' with {
          post: post,
          postScores: postScores[post.id]|default({}),
          userVote: userVotes[post.id]|default(null)
        } %}
      </div>
    {% else %}
      <div class="col-12">
        <div class="alert alert-info text-center py-5">
          Soyez le premier à témoigner !
        </div>
      </div>
    {% endfor %}
  </div>
  {# </div> #}
{% endblock %}
