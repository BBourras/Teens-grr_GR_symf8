{# templates/dashboard/my_posts.html.twig #}

{% extends 'base.html.twig' %}

{% block title %}Mes posts - {{ app.user.username }}{% endblock %}

{% block body %}
    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-start mb-4">
            <h1>
                <i class="bi bi-file-earmark-text me-3"></i>
                Mes posts ({{ pagination.totalItemCount }})
            </h1>

            <div class="d-flex flex-column align-items-end gap-2">
                <a href="{{ path('user_dashboard') }}" class="btn btn-outline-secondary">
                    ← Retour au tableau de bord
                </a>

                <a href="{{ path('post_create') }}" class="btn btn-primary">
                    <i class="bi bi-plus-circle me-1"></i>
                    Nouveau post
                </a>
            </div>
        </div>

        {% if pagination is empty %}
            <div class="alert alert-info text-center py-5">
                <i class="bi bi-file-earmark-text display-4 text-muted mb-3"></i>
                <h5>Vous n'avez encore publié aucun post.</h5>
                <a href="{{ path('post_create') }}" class="btn btn-primary mt-3">Créer mon premier post</a>
            </div>
        {% else %}
            <div class="row row-cols-1 row-cols-lg-2 g-4 mb-5">
                {% for post in pagination %}
                    <div class="col">
                        <div class="card h-100">
                            <div class="card-body">
                                <h5 class="card-title">{{ post.title }}</h5>

                                <p class="card-text text-muted small mb-2">
                                    {{ post.createdAt|date('d/m/Y - H:i') }}
                                </p>

                                <p class="card-text">
                                    {{ post.content|slice(0, 180) }}
                                    {% if post.content|length > 180 %}…{% endif %}
                                </p>

                                <div class="mt-3">
                                    <span class="badge 
                                        {% if post.isVisible() %}bg-success
                                        {% elseif post.isAutoModerated() %}bg-warning
                                        {% elseif post.isManuallyModerated() %}bg-danger
                                        {% else %}bg-secondary{% endif %}">
                                        {{ post.getStatusEnum().label() }}
                                    </span>
                                </div>
                            </div>
                            <div class="card-footer bg-transparent d-flex gap-2">
                                <a href="{{ path('post_show', {id: post.id}) }}" class="btn btn-sm btn-outline-primary flex-fill">
                                    <i class="bi bi-eye"></i> Voir
                                </a>

                                {% if post.isVisible() or post.isHidden() %}
                                    <a href="{{ path('post_edit', {id: post.id}) }}" class="btn btn-sm btn-outline-secondary flex-fill">
                                        <i class="bi bi-pencil"></i> Modifier
                                    </a>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>

            <!-- === PAGINATION KNPPAGINATOR === -->
            <div class="d-flex justify-content-center mt-5">
                {{ knp_pagination_render(pagination) }}
            </div>
        {% endif %}
    </div>
{% endblock %}